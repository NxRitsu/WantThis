# Copie ce fichier en ".env" et renseigne tes vraies valeurs Supabase.
# (Settings -> API dans le dashboard Supabase)
#
# Ces variables sont injectées au build par Vite. La clé "anon" est PUBLIQUE
# par design : la sécurité repose sur le Row Level Security, pas sur son secret.
# Ne mets JAMAIS la clé "service_role" ici.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
